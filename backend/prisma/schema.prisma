generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  email         String    @unique
  passwordHash  String
  avatar        String?
  bio           String?    @db.Text
  experience    String?    // Junior, Mid, Senior
  reputation    Int       @default(0)
  lastActiveAt  DateTime? 
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  posts         Post[]
  comments      Comment[]
  likes         Like[]
  following     Follow[]   @relation("Following")
  followers     Follow[]   @relation("Followers")
  skills        UserSkill[]
  notifications Notification[]
  activities    UserActivity[]
  badges        Badge[]
  reputationTxs ReputationTransaction[]
  techFollows   UserTechnologyFollow[]
  postViews     PostView[]
}

model UserSkill {
  id        String   @id @default(cuid())
  userId    String
  skill     String   // React, TypeScript, Node.js, etc.
  level     String   // Beginner, Intermediate, Advanced
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, skill])
}

model Post {
  id          String    @id @default(cuid())
  title       String
  content     String    @db.Text
  imageUrl    String?
  authorId    String
  tags        String[]  // Technology tags array
  shares      Int       @default(0)
  views       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments    Comment[]
  likes       Like[]
  viewsEvents PostView[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  authorId  String
  postId    String
  createdAt DateTime @default(now())
  
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  @@unique([userId, postId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)
  
  @@unique([followerId, followingId])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String   // Who receives the notification
  type        String   // LIKE, FOLLOW, COMMENT
  actorId     String   // Who performed the action
  actorName   String   // Denormalized for performance
  postId      String?  // Optional: if notification is about a post
  commentId   String?  // Optional: if notification is about a comment
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  action    String
  metadata  Json
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserTechnologyFollow {
  id          String   @id @default(cuid())
  userId      String
  technology  String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, technology])
}

model PostView {
  id         String   @id @default(cuid())
  postId     String
  userId     String
  ipAddress  String?
  userAgent   String?
  createdAt  DateTime @default(now())

  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Badge {
  id         String   @id @default(cuid())
  userId     String
  name       String
  awardedAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model ReputationTransaction {
  id        String   @id @default(cuid())
  userId    String
  action    String
  points    Int
  metadata  String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
